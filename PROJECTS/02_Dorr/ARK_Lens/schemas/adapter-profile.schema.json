{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ark-lens.local/schemas/adapter-profile.schema.json",
  "title": "ARK Lens Adapter Repair Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "adapter_id",
    "version",
    "display_name",
    "item_type",
    "fields",
    "job_id",
    "readiness"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z0-9][a-z0-9_-]+$"
    },
    "adapter_id": {
      "enum": ["linkedin_jobs", "seek_jobs"]
    },
    "version": { "type": "string", "minLength": 1, "maxLength": 80 },
    "display_name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "item_type": { "const": "job" },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detail_root",
        "fallback_root",
        "title",
        "company",
        "location",
        "description",
        "apply_button",
        "recommendation_link"
      ],
      "properties": {
        "detail_root": { "$ref": "#/$defs/selectors" },
        "fallback_root": { "$ref": "#/$defs/selectors" },
        "title": { "$ref": "#/$defs/selectors" },
        "company": { "$ref": "#/$defs/selectors" },
        "location": { "$ref": "#/$defs/selectors" },
        "description": { "$ref": "#/$defs/selectors" },
        "applied_message": { "$ref": "#/$defs/selectors" },
        "applied_link": { "$ref": "#/$defs/selectors" },
        "apply_button": { "$ref": "#/$defs/selectors" },
        "workspace_root": { "$ref": "#/$defs/selectors" },
        "recommendation_link": { "$ref": "#/$defs/selectors" },
        "posted": { "$ref": "#/$defs/selectors" },
        "work_type": { "$ref": "#/$defs/selectors" },
        "salary": { "$ref": "#/$defs/selectors" },
        "classification": { "$ref": "#/$defs/selectors" }
      }
    },
    "job_id": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url_patterns", "query_params", "link_selectors"],
      "properties": {
        "url_patterns": { "$ref": "#/$defs/strings" },
        "query_params": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.-]{0,79}$"
          }
        },
        "link_selectors": { "$ref": "#/$defs/selectors" }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_description_length", "allow_applied_without_description"],
      "properties": {
        "min_description_length": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "allow_applied_without_description": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "strings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "selectors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    }
  }
}
